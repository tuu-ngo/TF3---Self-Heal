{
  "profile_name": "cdo-tenant-selfheal",
  "system": "K8S_NATIVE",
  "default_namespace": "tenant-a",
  "default_deployment_template": "deployment/{{target_service}}",
  "default_service": "cdo-sample-api",
  "allowed_namespaces": [
    "tenant-a",
    "tenant-b"
  ],
  "services": [
    "cdo-sample-api",
    "notification-service"
  ],
  "metric_types": [
    "cpu",
    "mem",
    "delay",
    "loss",
    "socket",
    "disk"
  ],
  "fault_runbook_mapping": {
    "cpu": "ServiceStuckRestartRunbook",
    "mem": "OOMPatchMemoryRunbook",
    "delay": "ServiceStuckRestartRunbook",
    "loss": "ServiceStuckRestartRunbook",
    "disk": "ServiceStuckRestartRunbook",
    "socket": "ServiceStuckRestartRunbook",
    "f1": "DefaultRecoveryRunbook",
    "f2": "DefaultRecoveryRunbook",
    "f3": "DefaultRecoveryRunbook",
    "f4": "DefaultRecoveryRunbook",
    "f5": "DefaultRecoveryRunbook"
  },
  "dependency_graph": {
    "cdo-sample-api": [
      "notification-service"
    ],
    "notification-service": []
  },
  "runbooks": {
    "ServiceStuckRestartRunbook": {
      "name": "ServiceStuckRestartRunbook",
      "description": "Restart deployment for treo/latency/lỗi tạm thời (urgent path, CDO executes via K8s API).",
      "pattern_type": "urgent",
      "action_plan": [
        {
          "step": 1,
          "action": "RESTART_DEPLOYMENT",
          "target": "deployment/{{target_service}}",
          "params": {
            "namespace": "tenant-a",
            "grace_period_seconds": 30
          }
        }
      ],
      "blast_radius_config": {
        "max_pod_impact_pct": 25,
        "circuit_breaker_error_rate": 0.2,
        "allowed_namespaces": [
          "tenant-a",
          "tenant-b"
        ]
      },
      "verify_policy": {
        "window_seconds": 120,
        "success_conditions": [
          "pod_ready == true",
          "service_error_rate < 0.01"
        ]
      }
    },
    "OOMPatchMemoryRunbook": {
      "name": "OOMPatchMemoryRunbook",
      "description": "Patch memory limit khi OOM/memory pressure (≤4096Mi cap khớp safety gate + Kyverno). Container 'podinfo'.",
      "pattern_type": "urgent",
      "action_plan": [
        {
          "step": 1,
          "action": "PATCH_MEMORY_LIMIT",
          "target": "deployment/{{target_service}}",
          "params": {
            "namespace": "tenant-a",
            "container": "podinfo",
            "memory_request_mb": 256,
            "memory_limit_mb": 1024
          }
        }
      ],
      "blast_radius_config": {
        "max_pod_impact_pct": 25,
        "circuit_breaker_error_rate": 0.2,
        "allowed_namespaces": [
          "tenant-a",
          "tenant-b"
        ]
      },
      "verify_policy": {
        "window_seconds": 120,
        "success_conditions": [
          "pod_ready == true",
          "restart_count_no_increase == true"
        ]
      }
    },
    "DefaultRecoveryRunbook": {
      "name": "DefaultRecoveryRunbook",
      "description": "Fallback restart cho fault code-level/unknown (RE3 f1-f5).",
      "pattern_type": "urgent",
      "action_plan": [
        {
          "step": 1,
          "action": "RESTART_DEPLOYMENT",
          "target": "deployment/{{target_service}}",
          "params": {
            "namespace": "tenant-a",
            "grace_period_seconds": 30
          }
        }
      ],
      "blast_radius_config": {
        "max_pod_impact_pct": 25,
        "circuit_breaker_error_rate": 0.2,
        "allowed_namespaces": [
          "tenant-a",
          "tenant-b"
        ]
      },
      "verify_policy": {
        "window_seconds": 120,
        "success_conditions": [
          "pod_ready == true"
        ]
      }
    }
  }
}
