# =====================================================================
# detect_decide_verify stage environment template
# BOCPD anomaly detection + BARO RCA + staged detect/decide/verify APIs.
# Copy this file to `.env` and adjust values for your bench or production cluster.
# Do not commit real API keys or cluster-specific secrets.
# =====================================================================

# ---------------------------------------------------------------------
# Shared benchmark/profile assets
# ---------------------------------------------------------------------
DATASET_DIR=./adr  
GROUND_TRUTH_PATH=./adr/ground_truth.json
RUNBOOKS_PATH=./adr/runbooks.json
DEPENDENCY_GRAPH_PATH=./adr/dependency_graph.json
PLATFORM_PROFILE_PATH=./adr/platform_profile_online_boutique.json
PLATFORM_PROFILE_SCHEMA_PATH=./adr/platform_profile.schema.json

# Architecture catalogs are loaded from PLATFORM_PROFILE_PATH JSON.
# Do NOT define SERVICES_LIST or METRIC_TYPES_LIST here; edit the profile JSON:
# - services
# - metric_types
# - fault_runbook_mapping
# following platform_profile.schema.json.
SYSTEM_NAME=E-COMMERCE
DEFAULT_NAMESPACE=production
DEFAULT_DEPLOYMENT_TEMPLATE=deployment/{{target_service}}
DEFAULT_SERVICE=checkoutservice
ALLOWED_NAMESPACES=production,default

# ---------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8050

# ---------------------------------------------------------------------
# Detect/RCA hyperparameters
# ---------------------------------------------------------------------
BASELINE_LENGTH=600
BOCPD_HAZARD=50

CORRELATION_THRESHOLD=0.25
ANALYSIS_WINDOW_SIZE=120
USE_BARO_RCA=True
BARO_TOP_K=3
BARO_RCA_CONFIDENCE=0.90

DRAIN_SIM_TH=0.05
DRAIN_DEPTH=4
LOG_ERROR_KEYWORDS=(error|exception|fail|timeout|exhaust|limit|abort|invalid|refused|conn|crash|oom|kill)

RCA_ZSCORE_THRESHOLD=2.0
RCA_ZSCORE_MAX_CONTRIBUTION=500.0
RCA_LOG_METRIC_DEFAULT_WEIGHT=1.0
RCA_LOG_METRIC_COLOCATED_WEIGHT=3.0
RCA_LOG_METRIC_MULTIPLIER=25.0
RCA_CONFIDENCE_MAX=0.95
RCA_CONFIDENCE_BASE=0.70
RCA_CONFIDENCE_DIVISOR=200.0
RCA_SMOOTHING_WINDOW=15
RCA_DEVIATION_WINDOW=30
RCA_ANALYSIS_WINDOW_AFTER=10
RCA_STD_REG_MULTIPLIER=0.05
RCA_STD_REG_ADDITIVE=0.05

# Generic fault-type inference scoring. Override only when another CDO team uses
# different signal names; do not hardcode team/service-specific catalogs here.
FAULT_SIGNAL_PATTERNS=cpu:cpu|processor|core;mem:mem|memory|oom|rss|heap;disk:disk|diskio|disk_io|io|iops|fs|filesystem;socket:socket|connection|conn|fd|file_descriptor|tcp;loss:loss|packet|error|error_rate|unavailable|reset|refused|deadline|no healthy|dropped;delay:latency|delay|p95|p90|p99|timeout|duration|slow
FAULT_SIGNAL_WEIGHTS=cpu:1.2,mem:2.0,disk:3.5,socket:5.5,loss:3.2,delay:0.9
FAULT_LOG_EVIDENCE_WEIGHT=12.0
FAULT_BARO_RANK_WEIGHT=1.5
FAULT_SCORE_MIN=1.0

# ---------------------------------------------------------------------
# Verify stage thresholds
# ---------------------------------------------------------------------
ALERT_HEALING_WINDOW_SECONDS=120
VERIFY_ERROR_THRESHOLD=0.05
VERIFY_LATENCY_THRESHOLD=0.5
VERIFY_REGRESSION_ERROR_THRESHOLD=0.10

# ---------------------------------------------------------------------
# Benchmark fixture slicing around inject_time
# ---------------------------------------------------------------------
EVAL_BOCPD_WINDOW_BEFORE=80
EVAL_BOCPD_WINDOW_AFTER=30
EVAL_BOCPD_BASELINE_LENGTH=50

# ---------------------------------------------------------------------
# Server-side telemetry source mode
# ---------------------------------------------------------------------
# bench:
#   /v1/detect reads local deterministic dataset fixtures when caller sends
#   telemetry_source.kind=benchmark_fixture. This is the default for benchmarks.
# production:
#   /v1/detect reads logs/metrics from Kubernetes/Prometheus when no explicit
#   telemetry_window is sent.
# Supported source kinds: benchmark_fixture | k8s | prometheus_loki
TELEMETRY_RUNTIME_MODE=bench
BENCH_TELEMETRY_SOURCE_KIND=benchmark_fixture
PRODUCTION_TELEMETRY_SOURCE_KIND=k8s

# Leave empty to derive from TELEMETRY_RUNTIME_MODE:
# - bench      -> BENCH_TELEMETRY_SOURCE_KIND
# - production -> PRODUCTION_TELEMETRY_SOURCE_KIND
# Set explicitly only if you need to force one source kind regardless of mode.
DEFAULT_TELEMETRY_SOURCE_KIND=

# ---------------------------------------------------------------------
# Kubernetes telemetry reader (production/k8s mode)
# ---------------------------------------------------------------------
# AI Engine only reads telemetry; it must not mutate Kubernetes resources.
# For local development with kubeconfig:
#   K8S_IN_CLUSTER=False
#   K8S_CONTEXT=<your-context-or-empty-for-current>
# For running inside the cluster:
#   K8S_IN_CLUSTER=True
K8S_NAMESPACE=production
K8S_CONTEXT=
K8S_IN_CLUSTER=False

# Optional label selector for target pods/services.
# Examples:
#   K8S_LABEL_SELECTOR=app.kubernetes.io/part-of=online-boutique
#   K8S_LABEL_SELECTOR=app=checkoutservice
K8S_LABEL_SELECTOR=

# Ordered label keys used to map pod -> logical service name.
K8S_SERVICE_LABEL_KEYS=app.kubernetes.io/name,app,service,k8s-app

# Empty = read all containers in each selected pod. Or set comma-separated names.
K8S_CONTAINER_NAMES=

# Pod log window controls.
K8S_LOG_SINCE_SECONDS=300
K8S_LOG_TAIL_LINES=500

# ---------------------------------------------------------------------
# Metrics provider
# ---------------------------------------------------------------------
# Supported currently:
# - prometheus: query CPU/memory time series from Prometheus HTTP API
# - none: logs-only smoke/dev mode; detect may return NO_METRICS if no metrics exist
K8S_METRICS_PROVIDER=prometheus
K8S_METRIC_WINDOW_SECONDS=300
PROMETHEUS_BASE_URL=http://prometheus-server.monitoring.svc.cluster.local:9090
PROMETHEUS_QUERY_STEP_SECONDS=15
PROMETHEUS_REQUEST_TIMEOUT_SECONDS=10

# Reserved for future Loki log queries. Current prometheus_loki mode uses
# Prometheus for metrics and Kubernetes API for pod logs.
LOKI_BASE_URL=

# ---------------------------------------------------------------------
# LLM decision / fault-ranking support
# ---------------------------------------------------------------------
# Keep disabled for deterministic offline benchmarks. Enable only when network
# calls and credentials are allowed.
USE_LLM_DECISION=False

# Optional LLM fault-type ranking. /v1/decide calls it only when
# detect_evidence.rank_fault_catalog_for_topk_service=True.
USE_LLM_FAULT_TYPE=False

# Supported providers: openai, anthropic, bedrock
LLM_PROVIDER=openai

# Model examples:
# - OpenAI-compatible: gpt-4o
# - Anthropic:         claude-3-5-sonnet-20241022
# - Bedrock:           us.anthropic.claude-3-5-sonnet-20241022-v2:0
LLM_MODEL=gpt-4o

# OpenAI-compatible configuration
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Anthropic configuration
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages

# AWS Bedrock configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=
